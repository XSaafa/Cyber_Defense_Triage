{
  "name": "cyber-triage-mcp",
  "version": "1.0.0",
  "description": "Cyber-Defense Triage First Responder - MCP server, CLI tool, and web dashboard",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dashboard": "cd dashboard && npm run dev",
    "agent": "node agent/httpServer.js",
    "investigate": "node agent/investigator.js",
    "cli": "node cli/triage-cli.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "cd dashboard && npm run build",
    "lint": "eslint . --ext .js",
    "lint:fix": "eslint . --ext .js --fix"
  },
  "keywords": ["security", "cybersecurity", "incident-response", "triage", "mcp"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.36.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "zod": "^4.3.6",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "vitest": "^1.0.4",
    "eslint": "^8.56.0"
  },
  "type": "module",
  "bin": {
    "cyber-triage-mcp": "./server.js"
  }
}