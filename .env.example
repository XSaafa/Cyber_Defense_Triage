# Threat Intelligence API Keys
# Copy this file to .env and add your API keys

# Groq API Key — required for the AI Investigator agent (free at https://console.groq.com)
GROQ_API_KEY=your_groq_api_key_here

# AlienVault OTX (Free - https://otx.alienvault.com/)
OTX_API_KEY=your_otx_api_key_here

# AbuseIPDB (Free tier - https://www.abuseipdb.com/)
ABUSEIPDB_API_KEY=your_abuseipdb_api_key_here

# VirusTotal (Free tier - https://www.virustotal.com/)
VIRUSTOTAL_API_KEY=your_virustotal_api_key_here

# Shodan (Optional - https://www.shodan.io/)
SHODAN_API_KEY=your_shodan_api_key_here

# NVD - National Vulnerability Database (Optional - https://nvd.nist.gov/developers/request-an-api-key)
NVD_API_KEY=your_nvd_api_key_here

# Cache settings
THREAT_INTEL_CACHE_TTL=3600
THREAT_INTEL_CACHE_ENABLED=true
